pipeline { 
agent any 
stages { 
stage('checkout') { 
steps { 
echo 'git checkout stage' 
git branch: 'main', url: 'https://github.com/devopstraininghub/mindcircuit17d.git' 
} 
} 
stage('build') { 
steps { 
echo 'building with maven' 
sh 'mvn clean install' 
} 
} 
stage('deploy') { 
